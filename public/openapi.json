{
  "openapi": "3.0.0",
  "info": {
    "title": "FinZ LMS - Super Admin API Reference",
    "description": "Complete Swagger/OpenAPI documentation for the FinZ LMS Super Admin panel mapping all Phase 1-3 (Screens 01 to 13) features. Includes SSO, failed login CAPTCHAs, MFA skip controls, dashboard feeds, health metrics, bookmarked search commands, auditable impersonation gates, Spatie permission rollbacks, and IP allowance policies.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8000",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "summary": "Login (Get JWT Token)",
        "description": "Checks email/password, checks IP rules, evaluates brute-force lockouts, and generates a math CAPTCHA puzzle challenge if attempts >= 3 in 10 minutes.",
        "tags": ["1. Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "superadmin@finz.com" },
                  "password": { "type": "string", "minLength": 6, "example": "password" },
                  "captcha_key": { "type": "string", "example": "optional-uuid-here" },
                  "captcha_answer": { "type": "string", "example": "optional-math-answer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful or MFA required." }
        }
      }
    },

    "/api/v1/auth/mfa/verify": {
      "post": {
        "summary": "Verify MFA Code",
        "description": "Validates 6-digit Google TOTP, Email OTP, or recovery codes. Supports skip-MFA cookies.",
        "tags": ["1. Authentication"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["otp"],
                "properties": {
                  "otp": { "type": "string", "example": "123456" },
                  "remember_device": { "type": "boolean", "example": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "MFA verified." }
        }
      }
    },
    "/api/v1/auth/mfa/resend": {
      "post": {
        "summary": "Resend MFA Email OTP",
        "tags": ["1. Authentication"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "OTP sent successfully." }
        }
      }
    },

    "/api/v1/auth/logout": {
      "post": {
        "summary": "Logout Admin",
        "description": "Invalidates JWT token and marks the logged-in session active status to false.",
        "tags": ["1. Authentication"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Logged out successfully." }
        }
      }
    },
    "/api/v1/auth/mfa/toggle": {
      "post": {
        "summary": "Toggle Global MFA Switch (Project level)",
        "description": "Toggles Multi-Factor Authentication project-wide. If disabled, all users can bypass MFA during logins instantly.",
        "tags": ["1. Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["enabled"],
                "properties": {
                  "enabled": { "type": "boolean", "example": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Global MFA status successfully updated." }
        }
      }
    },
    "/api/v1/auth/forgot-password": {
      "post": {
        "summary": "Request Password Reset Link",
        "tags": ["1. Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "example": "superadmin@finz.com" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Reset token link sent." }
        }
      }
    },
    "/api/v1/auth/reset-password": {
      "post": {
        "summary": "Reset Password via Token",
        "description": "Sets new password. Validates complexity and prevents reusing the last 5 passwords.",
        "tags": ["1. Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "token", "password", "password_confirmation"],
                "properties": {
                  "email": { "type": "string", "example": "superadmin@finz.com" },
                  "token": { "type": "string", "example": "reset_token_xyz" },
                  "password": { "type": "string", "example": "SecurePass123!" },
                  "password_confirmation": { "type": "string", "example": "SecurePass123!" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password reset successfully." }
        }
      }
    },
