    "/api/v1/admin/users/{id}/reset-password": {
      "post": {
        "summary": "Request Password Reset Verification Code",
        "description": "Super Admin only. Path id is the target user whose password will be reset. The email field must be the Super Admin's own login email — the verification code is sent there.",
        "tags": ["7. User Management"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "ID of the target user whose password will be reset" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "superadmin@finz.com", "description": "Super Admin login email (must match authenticated user)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Verification code sent to Super Admin email." },
          "403": { "description": "Only Super Admin can perform this action." },
          "422": { "description": "Email does not match Super Admin login email." }
        }
      }
    },
    "/api/v1/admin/users/{id}/change-password": {
      "put": {
        "summary": "Change User Password",
        "description": "Super Admin only. Path id is the target user. Sets a new password using the verification code sent to the Super Admin's email from reset-password.",
        "tags": ["7. User Management"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "ID of the target user whose password will be changed" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["verification_code", "new_password", "new_password_confirmation"],
                "properties": {
                  "verification_code": { "type": "string", "example": "123456", "description": "6-digit code sent to Super Admin email" },
                  "new_password": { "type": "string", "example": "SecurePass99!" },
                  "new_password_confirmation": { "type": "string", "example": "SecurePass99!" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password changed successfully for target user." },
          "403": { "description": "Only Super Admin can perform this action." },
          "422": { "description": "Invalid or expired verification code." }
        }
      }
    },
