{
  "info": {
    "name": "FinZ LMS - Super Admin API",
    "description": "Complete API collection for FinZ LMS Super Admin Panel (Phases 1-3, Screens 01-13)",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1️⃣ PUBLIC - Authentication & SSO (Screen 01, 03)",
      "item": [
        {
          "name": "Login (Get Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@finz.com\",\n  \"password\": \"password\",\n  \"captcha_key\": \"optional_uuid\",\n  \"captcha_answer\": \"optional_sum\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login with email and password. Generates CAPTCHA requirements if attempts >= 3."
          }
        },
        {
          "name": "Google SSO Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_token\": \"mock_google_id_token_xyz\",\n  \"email\": \"superadmin@finz.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/sso/google",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "sso", "google"]
            },
            "description": "Log in via Google SSO placeholder."
          }
        },
        {
          "name": "Microsoft SSO Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_token\": \"mock_microsoft_id_token_abc\",\n  \"email\": \"superadmin@finz.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/sso/microsoft",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "sso", "microsoft"]
            },
            "description": "Log in via Microsoft SSO placeholder."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@finz.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/forgot-password",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "forgot-password"]
            },
            "description": "Send password reset token link."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@finz.com\",\n  \"token\": \"mock_reset_token\",\n  \"password\": \"SecurePass123!\",\n  \"password_confirmation\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/reset-password",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "reset-password"]
            },
            "description": "Reset password using the generated token. Validates complexity and prevents reusing the last 5 passwords."
          }
        }
      ]
    },
    {
      "name": "2️⃣ MFA - Verification (Screen 02)",
      "item": [
        {
          "name": "Verify MFA (TOTP / Email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp\": \"123456\",\n  \"remember_device\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/mfa/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "mfa", "verify"]
            },
            "description": "Verify Google Authenticator TOTP or Email OTP code. Optionally issues a 30-day skip-MFA cookie."
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/mfa/resend",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "mfa", "resend"]
            },
            "description": "Resends a new email OTP if the previous one expired."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Issues a fresh JWT token before the current one expires."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Terminates the current token and flags the session active status to false."
          }
        }
      ]
    },
    {
      "name": "3️⃣ PROTECTED - Profile (Screen 04)",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "profile"]
            }
          }
        },
        {
          "name": "Change My Password",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"password\",\n  \"new_password\": \"SecurePass99!\",\n  \"new_password_confirmation\": \"SecurePass99!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/profile/change-password",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "profile", "change-password"]
            },
            "description": "Update password with a reuse validation check against the last 5 passwords."
          }
        },
        {
          "name": "MFA Setup (Enable/Disable)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"enable\",\n  \"channel\": \"totp\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/profile/mfa-setup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "profile", "mfa-setup"]
            }
          }
        }
      ]
    },
    {
      "name": "4️⃣ PROTECTED - Notification Center (Screen 05)",
      "item": [
        {
          "name": "Get All Notifications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/notifications?tab=all&page=1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "notifications"],
              "query": [
                {
                  "key": "tab",
                  "value": "all"
                },
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Mark All as Read",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/notifications/read-all",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "notifications", "read-all"]
            }
          }
        }
      ]
    },
    {
      "name": "5️⃣ PROTECTED - Command Center & Health (Screen 06, 07, 08)",
      "item": [
        {
          "name": "Get System Health Overview",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/system-health",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "system-health"]
            }
          }
        },
        {
          "name": "Global Search Query",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/search?q=merchant",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "merchant"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "6️⃣ PROTECTED - User Directory & Impersonation (Screen 09, 10)",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/users?role=merchant_admin",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "users"],
              "query": [
                {
                  "key": "role",
                  "value": "merchant_admin"
                }
              ]
            }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Store Owner\",\n  \"email\": \"storeowner@example.com\",\n  \"mobile\": \"9876543210\",\n  \"role\": \"store_manager\",\n  \"mfa_enabled\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/users",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "users"]
            }
          }
        },
        {
          "name": "Impersonate User (Audited Start)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Debugging permissions setup on store portal.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/users/2/impersonate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "users", "2", "impersonate"]
            },
            "description": "Logs in as another user, recording the audit logs with reason and admin context persistently in the database."
          }
        }
      ]
    },
    {
      "name": "7️⃣ PROTECTED - Permission Matrix & Snapshots (Screen 11, 12)",
      "item": [
        {
          "name": "Get Matrix Matrix",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/permissions",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "permissions"]
            }
          }
        },
        {
          "name": "Update Role Permissions (Backup Snapshots)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permissions\": [\"view_users\", \"edit_profile\", \"change_password\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/permissions/roles/2",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "permissions", "roles", "2"]
            },
            "description": "Applies new permissions to a role while backing up the old configuration snapshot inside the audit_logs table."
          }
        },
        {
          "name": "Rollback Permissions Matrix",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/permissions/roles/2/rollback",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "permissions", "roles", "2", "rollback"]
            },
            "description": "Pulls the latest database snapshot from audit_logs for the role and restores it."
          }
        }
      ]
    },
    {
      "name": "8️⃣ PROTECTED - Session & IP Restrictions (Screen 13)",
      "item": [
        {
          "name": "Get All Active Sessions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/sessions?suspicious=true",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "sessions"],
              "query": [
                {
                  "key": "suspicious",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Update IP & Session Rules",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"merchant_admin\",\n  \"allowlist\": [\"127.0.0.1\", \"192.168.1.0/24\"],\n  \"denylist\": [\"10.0.0.5\"],\n  \"concurrent_session_limit\": 3\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/sessions/ip-rules",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "sessions", "ip-rules"]
            },
            "description": "Updates persistent security policies (IP lists, concurrent limits) in role_configs table."
          }
        },
        {
          "name": "Revoke Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/sessions/1/revoke",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "sessions", "1", "revoke"]
            }
          }
        }
      ]
    }
  ]
}
